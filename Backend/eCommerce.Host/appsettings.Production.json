{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "FrontendUrl": "https://ecommerceprodstore.z23.web.core.windows.net",
  "ConnectionStrings": {
    "Default": "Data Source=/home/site/data/ecommerce.db;Mode=ReadWriteCreate;Cache=Shared;Foreign Keys=True;Pooling=false;Default Timeout=30"
  },
  "JWT": {
    "Secret": "YOUR_PRODUCTION_JWT_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG",
    "ValidIssuer": "eCommerceAPI",
    "ValidAudience": "eCommerceClient",
    "ExpiryInMinutes": 30
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "YOUR_PRODUCTION_EMAIL_ADDRESS",
    "SenderName": "LuxeLiving",
    "Username": "YOUR_PRODUCTION_EMAIL_ADDRESS",
    "Password": "YOUR_PRODUCTION_EMAIL_PASSWORD",
    "EnableSsl": true
  },
  "Stripe": {
    "PublishableKey": "pk_live_YOUR_STRIPE_LIVE_PUBLISHABLE_KEY",
    "SecretKey": "sk_live_YOUR_STRIPE_LIVE_SECRET_KEY",
    "WebhookSecret": "whsec_YOUR_LIVE_WEBHOOK_SECRET"
  },
  "AppSettings": {
    "FrontendUrl": "https://ecommerceprodstore.z23.web.core.windows.net",
    "EnableSwagger": true,
    "EnableDetailedErrors": false,
    "CacheExpirationMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "https://ecommerceprodstore.z23.web.core.windows.net"
    ]
  }
}